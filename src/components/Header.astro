---
// Header component using the existing styles and structure from the rest of your application
---

<header id="header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300 py-5 bg-transparent">
  <div class="container mx-auto px-4 md:px-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="https://www.aimadesimple.online" class="flex items-center space-x-2">
      <img 
        src="https://aimadesimple.online/_next/image?url=%2Flovable-uploads%2F4332a292-596f-4672-9e76-da187a3ab302.png&w=96&q=75" 
        alt="AIMadeSimple Logo" 
        class="h-10 w-auto"
      />
    </a>

    <!-- X (Making AI Simple) + Support -->
    <div class="flex items-center gap-2 shrink-0">
      <a
        href="https://x.com/makingAISimple"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full p-2.5 text-gray-700 transition-colors hover:bg-gray-100 hover:text-aimade-green focus:outline-none focus-visible:ring-2 focus-visible:ring-aimade-green focus-visible:ring-offset-2"
        aria-label="Making AI Simple on X"
      >
        <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
      <a
        href="https://aimadesimple.online/#support"
        class="bg-aimade-blue hover:bg-aimade-darkblue text-white rounded-lg px-6 py-2.5 font-medium button-hover-effect transition-all duration-300"
      >
        Support
      </a>
    </div>
  </div>
</header>

<script>
  // Add scroll behavior matching parent site
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.remove('py-5', 'bg-transparent');
      header?.classList.add('py-3', 'bg-white/90', 'backdrop-blur-sm', 'shadow-sm');
    } else {
      header?.classList.add('py-5', 'bg-transparent');
      header?.classList.remove('py-3', 'bg-white/90', 'backdrop-blur-sm', 'shadow-sm');
    }
  });
</script>